{
  "expo": {
    "name": "EverPage",
    "slug": "everpage",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "everpage",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.everpage.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "EverPage uses your photo library so you can set a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "EverPage saves images to your photo library.",
        "NSUserNotificationUsageDescription": "EverPage sends reading reminders and nudges from friends."
      }
    },
    "android": {
      "package": "app.everpage.mobile",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "EverPage uses your photo library so you can set a profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1C3A5A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
